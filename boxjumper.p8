pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
 -- main loop --

function _init()
	cls()
	poke(0x5f2d,1)
	
	if not(lvl~=nil) then
		lvl=0
		idlg()
		music(0)
		menuitem(1, 'restart level', function() reload() _init() end)
	end
	
	iplr()
	icon()
	ibox()
	ibut()
	iscr()
	
	cam={x=128*lvl,y=0}
	layers=0
		
end

function _update()
	if lines<=0 then
		uplr()
		ubut()
	 ucon()
	 ubox()
	 uscr(scr)
	 if collide(plr,4) then
	 	reload()
	 	lvl+=1
	 	sfx(1)
	 	_init() 	
	  music(-1)
	  music(0+lvl)
	 end
	 if stat(28,21) then
	  reload()
	  _init()
		end
	end
 udlg()
end

function _draw()
	cls()
	shader(0)
	map((cam.x/8),(cam.y/8)-16,cam.x,cam.y)
	fillp(0b00100100.1)
	rectfill(cam.x,cam.y,cam.x+128,cam.y+128,0)
	fillp()
	map()
	
	camera(cam.x,cam.y)
	dcon()
	dscr(scr)
	dbut()
	dbox()
	dplr()
	if layers>0 then
		shader(layers+2)
		dlayers()
	end
	ddlg(cam)
end

function shader(col)
	pal()
	if (col==5) col=2
	if col>0 then
		pal(3,col+128,1)
		pal(0,col+128,1)
		pal(7,col,1)
		pal(5,0,1)
	else
		pal(3,0,1)
	end
end

function dlayers()

	map(112,0,cam.x,cam.y)
	if layers>1 then
		map(112,16,cam.x,cam.y)
		if layers>2 then
			map(112,32,cam.x,cam.y)
			if layers>3 then
				map(112,48,cam.x,cam.y)
				if layers>4 then
					map(112,96,cam.x,cam.y)
				end
			end
		end
	end
	
end
-->8
-- player --

function iplr()
	plr={
	x=60+128*lvl,
	y=60,
	f=true,
	fr=0,
	box=false
	}
end

function uplr()
	if btn(⬆️) or btn(⬇️) or btn(⬅️) or btn(➡️) or stat(28,4) or stat(28,26) or stat(28,7) or stat(28,22) then
		move(plr)
		plr.fr+=0.5
		if (plr.fr>3.5) plr.fr=1
		sfx(4)
	else
		if (plr.fr>=.5 or plr.fr<-1) plr.fr=-.5
		plr.fr+=.03
	end
end

function dplr()
	spr(1+plr.fr,plr.x,plr.y,1,1,plr.f)
	if (plr.box==true) spr(70,plr.x,plr.y-5-min(plr.fr,1))
end

function move(o)
	
	lx=o.x
	ly=o.y

	if btn(⬅️) or stat(28,4) then
		o.x-=2
		plr.f=true
		if (collide(o,0)) o.x=lx
	end
	
	if btn(➡️) or stat(28,7) then
		plr.f=false
		o.x+=2
		if (collide(o,0))	o.x=lx
	end
	
	if btn(⬆️) or stat(28,26) then
		o.y-=2
		if (collide(o,0))	o.y=ly
	end
	
	if btn(⬇️) or stat(28,22) then
		o.y+=2
		if (collide(o,0))	o.y=ly
	end
	
end

function collide(o,f)
	
	local x1=(o.x+1)/8
	local y1=(o.y+1)/8
	local x2=(o.x+6)/8
	local y2=(o.y+7)/8
	
	local a=fget(mget(x1,y1),f)
	local b=fget(mget(x1,y2),f)
	local c=fget(mget(x2,y2),f)
	local d=fget(mget(x2,y1),f)
	
	if a or b or c or d then
		return true
	else
		return false
	end
	
end
-->8
-- hopping --

function icon()
	
	con={}
	hopcld=0
	near=false
	
	local a=0
	local b=0
	
	while a<=128 do
		while b<=64 do
			if fget(mget(a,b),1) then
				add(con,{x=a*8-4,y=b*8-4,fr=0})
			end
			b+=1
		end
		b=0
		a+=1
	end
	
end

function ucon()
	
	if hopcld<=0 then
		if btnp(🅾️) and plr.y-128>0 then
			plr.y-=128
			cam.y-=128
			layers-=1
			sfx(2)
			hopcld=5
		end
		
		if hopcld<=0 then
			near=false
			for c in all(con) do
				if dist(plr,c)<16 then
					near=true
					c.fr+=.5
					if (c.fr>=2) then 
						c.fr=2
					elseif c.fr==1 then
						sfx(9)
					end
					if btnp(❎) then
					 hopcld=5
					 plr.y+=128
						cam.y+=128
						layers+=1
						c.fr=0
						sfx(1)
						break
					end
				elseif c.fr>0 then
					c.fr=0
					sfx(10)
				end
			end
		end
	else
		hopcld-=1
	end
end

function dcon()
	for c in all(con) do
		spr(64+(2*c.fr),c.x-4,c.y-4,2,2)
	end
end
-->8
-- math --

function dist(a,b,modx,mody)
	
	if not(modx~=nil) then
		modx=0
		mody=0
	end
	
	local dx = ((a.x)-b.x+modx)/16
	local dy = ((a.y)-b.y+mody)/16
	
	local dist=sqrt(dx^2+dy^2)*18
		if dist>=0 then
			return dist
	end
	
	return 32767
	
end
-->8
-- boxes --

function ibox()
	
	box={}
	
	local a=0
	local b=0
	
	while a<=128 do
		while b<=64 do
			if fget(mget(a,b),3) then
				add(box,{x=a*8,y=b*8})
				mset(a,b,0)
			end
			b+=1
		end
		b=0
		a+=1
	end
	
end

function ubox()
	if near==false then
		if plr.box==true then
			if btnp(❎) then
				plr.box=false
				add(box,{x=plr.x,y=plr.y})
				sfx(5)
			end
		else
			for b in all(box) do
				if dist(plr,b)<16 and btnp(❎) then
					plr.box=true
					del(box,b) 
					sfx(6)
					break
				end
			end
		end
	end 
end

function dbox()
	for b in all(box) do
		spr(70,b.x,b.y)
	end

end
-->8
-- buttons --

function ibut()
	
	but={}
	
	local a=0
	local b=0
	
	while a<=128 do
		while b<=64 do
			if fget(mget(a,b),2) then
				add(but,{x=a*8,y=b*8,press=0})
			end
			b+=1
		end
		b=0
		a+=1
	end
	
end

function ubut()
	for u in all(but) do
		lp=u.press
		u.press=0
		for o in all(box) do
			if o.x>u.x-8 and o.x<u.x+16 and o.y>u.y-9 and o.y<u.y+8 then
				u.press=1
			end
		end
		if plr.x>u.x-8 and plr.x<u.x+16 and plr.y>u.y-8 and plr.y<u.y+8 then
			u.press=1
		end
		
		if lp~=u.press then
			local finalx=flr(u.x/128)*16+16
			local finaly=flr(u.y/128)*16+16
			local x=flr(u.x/128)*16
			local y=flr(u.y/128)*16
			while x<finalx do
				while y<finaly do
					if u.press==1 then
						if mget(x,y)==112 then
							mset(x,y,113)
						end
						sfx(7)
					else
						if mget(x,y)==113 then
							mset(x,y,112)
						end
						sfx(8)
					end
					y+=1
				end
				y=flr(u.y/128)*16
				x+=1
			end
		end
		
	end
	
end

function dbut()
	for b in all(but) do
		spr(100-b.press*4,b.x,b.y,2,1)
	end
end
-->8
-- dialogue --

function idlg()
	setdlg()
	dlgnum=1
	lines=5
	dlgcld=0
	dlgfr=0
	bgfr=0
end

function udlg()
	
	if lines>0 then
		if btnp(❎) and dlgcld<=0 then
			dlgnum+=1
			lines-=1
			dlgcld=15
			dlgfr=0
			sfx(13)
		elseif dlgcld>0 then
			dlgcld-=1
		end
	end
	if lines<1 then
		if near==true and dlgnum==6 then
			lines=3
		end
		if hopcld>0 and dlgnum==9 then
			lines=2
			hopcld=0
		end
		if hopcld>0 and dlgnum==11 then
			lines=2
			hopcld=0
		end
		if lvl==1 and dlgnum==13 then
			lines=2
		end
		if lvl==2 and dlgnum==15 then
			lines=1
		end
		if lvl==3 and dlgnum==16 then
			lines=2
		end
		if lvl==6 and dlgnum==18 then
			lines=1
		end
		if ending==true and dlgnum==19 then
			lines=5
		end
		if dlgnum>=24 then
			if btnp(❎) then
				run()
			end
		end
	end
end

function ddlg(c)
	if dlgnum<=4 or ending==true then
		if dlgnum==3 or dlgnum==4 then
			bgfr+=.2
		elseif ending==true then
			bgfr-=.2
		end
		if bgfr<=1 then
			rectfill(c.x,c.y,c.x+128,c.y+128,0)
		elseif bgfr<=2 then
			fillp(0b00100100.1)
			rectfill(c.x,c.y,c.x+128,c.y+128,0)
		elseif bgfr<=3 then
			fillp(▒)
			rectfill(c.x,c.y,c.x+128,c.y+128,0)
		elseif bgfr<=4 then
			fillp(░)
			rectfill(c.x,c.y,c.x+128,c.y+128,0)
		end
	end
	if ending==true and dlgnum>22 then
	 rectfill(c.x,c.y,c.x+128,c.y+128,0)
	end
	fillp()
	if lines>0 then
		rectfill(3+c.x,3+c.y,124+c.x,36+c.y,0)
		rect(3+c.x,3+c.y,124+c.x,36+c.y,7)
		print(dlg[dlgnum],6+c.x,6+c.y)
		print('X TO CONTINUE', 71+c.x,30+c.y,7)
	end
end

