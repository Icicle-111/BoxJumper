-- big screen --

function iscr()
	scr={}
	ending=false
	local a=96
	local b=0
	while a<=112 do
		while b<=16 do
			if mget(a,b)==71 then
				scr={x=a*8,y=b*8,fr=0}
			end
			b+=1
		end
		b=0
		a+=1
	end
end

function uscr(s)
	if dist(plr,s,-24,-16)<24 then
		s.fr+=.2
		if (s.fr>=9) then 
			s.fr=-7
		elseif s.fr==.1 then
			sfx(9)
		end
		if btnp(❎) then
			ending=true
			dlgnum=19
			bgfr=4
			sfx(1)
			music(-1)
		end
	elseif s.fr~=0 then
		s.fr=0
		sfx(10)
	end
end

function dscr(s)
	spr(71+s.fr,s.x,s.y,3,4)
 spr(71+s.fr,s.x+24,s.y,3,4,true)
end
